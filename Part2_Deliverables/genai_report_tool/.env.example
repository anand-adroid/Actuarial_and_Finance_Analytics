# Copy this file to ".env" and fill in your key. .env is loaded automatically.
# Never commit your real .env to version control.

OPENAI_API_KEY=sk-your-key-here
# Optional overrides:
OPENAI_MODEL=gpt-4o            # or gpt-4o-mini for lower cost
LLM_BACKEND=openai            # openai | anthropic | azure | mock

# Only if using Anthropic (LLM_BACKEND=anthropic):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Retrieval embedder: sentence-transformers (default, local) | openai | tfidf
EMBEDDER=sentence-transformers
